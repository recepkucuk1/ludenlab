{
  "name": "@ludenlab/billing",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["dist"],
  "scripts": {
    "dist": "tsup src/index.ts --format esm,cjs --dts --clean",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prepack": "tsup src/index.ts --format esm,cjs --dts --clean"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "dependencies": {
    "iyzipay": "^2.0.67"
  },
  "devDependencies": {
    "@ludenlab/config": "workspace:*",
    "@types/iyzipay": "^2.0.3",
    "@types/node": "^22",
    "eslint": "^9.17.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.3"
  }
}
