generator client {
  provider = "prisma-client"
  output   = "../../src/generated/studio"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum PlanType {
  FREE
  PRO
  ADVANCED
  ENTERPRISE
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
}

enum CreditTransactionType {
  EARN
  SPEND
}

enum LessonStatus {
  PLANNED
  COMPLETED
  CANCELLED
}

enum ToolType {
  LEARNING_CARD
  SOCIAL_STORY
  ARTICULATION_DRILL
  HOMEWORK_MATERIAL
  WEEKLY_PLAN
  SESSION_SUMMARY
  MATCHING_GAME
  PHONATION_ACTIVITY
  COMMUNICATION_BOARD
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Therapist {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String
  password           String
  specialty          String[] // ["speech", "language", "hearing"]
  role               String    @default("user") // "user" | "admin"
  emailVerified      Boolean   @default(false)
  emailVerifyToken   String?   @unique
  emailVerifyExpires DateTime?
  autoLoginToken     String?   @unique
  autoLoginExpires   DateTime?
  credits            Int       @default(0)
  studentLimit       Int       @default(2)
  pdfEnabled         Boolean   @default(false)
  planType           PlanType  @default(FREE)
  suspended          Boolean   @default(false)
  lastLogin          DateTime?
  avatarUrl          String?   @db.Text
  institution        String?
  phone              String?
  experienceYears    String?
  certifications     String?   @db.Text
  preferences        Json?
  // KVKK uyumluluğu — admin "bu kullanıcı olarak giriş" yapabilmesi için
  // kullanıcının açık rızası gerekir. expiresAt > now ise consent aktiftir.
  // reason: kullanıcının "neden destek istiyorum" notu (opsiyonel).
  supportAccessExpiresAt DateTime?
  supportAccessReason    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  students            Student[]
  cards               Card[]
  progress            StudentProgress[]
  subscriptions       Subscription[]
  creditTxns          CreditTransaction[]
  lessons             Lesson[]
  passwordResetTokens PasswordResetToken[]
  apiUsageLogs        ApiUsageLog[]
}

/// Her Claude API çağrısının teknik maliyet kaydı. Kredi sistemi (business)
/// ile karıştırılmamalıdır — bu yalnızca mühendislik gözlemlenebilirliği için.
/// Thinking token'ları output'a dahil edilir (Anthropic faturalaması da öyle).
model ApiUsageLog {
  id               String   @id @default(cuid())
  therapistId      String
  endpoint         String // "cards/generate", "tools/social-story", vs.
  model            String // "claude-sonnet-4-6"
  inputTokens      Int      @default(0) // cache dışı ham input
  outputTokens     Int      @default(0) // thinking dahil
  cacheWriteTokens Int      @default(0)
  cacheReadTokens  Int      @default(0)
  costUsd          Decimal  @db.Decimal(10, 6)
  createdAt        DateTime @default(now())

  therapist Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([therapistId, createdAt])
  @@index([createdAt])
}

model Plan {
  id           String   @id @default(cuid())
  type         PlanType @unique
  studentLimit Int // -1 = sınırsız
  creditAmount Int // dönem başı yüklenen kredi
  monthlyPrice Int // kuruş cinsinden (37900 = 379 TL)
  yearlyPrice  Int // kuruş cinsinden
  pdfEnabled   Boolean
  // ── iyzico referans alanları ──
  iyzicoProductRef     String? // iyzico ürün referans kodu
  iyzicoMonthlyPlanRef String? // aylık planın iyzico referans kodu
  iyzicoYearlyPlanRef  String? // yıllık planın iyzico referans kodu
  createdAt    DateTime @default(now())

  subscriptions Subscription[]
}

model Subscription {
  id               String             @id @default(cuid())
  therapistId      String
  planId           String
  status           SubscriptionStatus @default(PENDING)
  billingCycle     BillingCycle
  currentPeriodEnd DateTime
  // ── iyzico referans alanları ──
  iyzicoSubscriptionRef String?        @unique // iyzico subscription reference code
  iyzicoCustomerRef     String?                // iyzico customer reference code
  iyzicoPricingPlanRef  String?                // seçilen iyzico plan referansı
  cancelledAt           DateTime?              // iptal tarihi
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  therapist Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  plan      Plan      @relation(fields: [planId], references: [id])
}

model CreditTransaction {
  id          String                @id @default(cuid())
  therapistId String
  amount      Int
  type        CreditTransactionType
  description String
  createdAt   DateTime              @default(now())

  therapist Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([therapistId])
}

model Student {
  id            String    @id @default(cuid())
  name          String
  birthDate     DateTime?
  workArea      String    @default("speech") // "speech" | "language" | "hearing"
  diagnosis     String?
  notes         String?
  curriculumIds String[]  @default([])
  aiProfile     String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  therapistId String
  therapist   Therapist         @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  cards       Card[]
  assignments CardAssignment[]
  progress    StudentProgress[]
  lessons     Lesson[]

  @@index([therapistId])
}

model Card {
  id         String   @id @default(cuid())
  title      String
  content    Json
  toolType   ToolType @default(LEARNING_CARD)
  category   String?  // "speech" | "language" | "hearing" | "fluency" | "voice"
  difficulty String // "easy" | "medium" | "hard"
  ageGroup   String // "3-6" | "7-12" | "13-18" | "adult"
  prompt     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  therapistId String
  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  curriculumGoalIds String[] @default([])

  assignments CardAssignment[]

  @@index([therapistId])
  @@index([studentId])
  @@index([category])
}

model CardAssignment {
  id         String   @id @default(cuid())
  cardId     String
  studentId  String
  status     String   @default("not_started") // "not_started" | "in_progress" | "completed"
  assignedAt DateTime @default(now())

  card    Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([cardId, studentId])
}

model Curriculum {
  id    String @id @default(cuid())
  code  String // "1.1", "1.2"
  area  String // "speech" | "language" | "hearing"
  title String // "Kekemelik"

  goals CurriculumGoal[]
}

model CurriculumGoal {
  id         String  @id @default(cuid())
  code       String // "1.0", "1.1", "2.0"
  title      String // "Konuşma sırasında nefes kontrolünü sağlar"
  isMainGoal Boolean // true = ana hedef (1.0), false = alt hedef (1.1)

  curriculumId String
  curriculum   Curriculum @relation(fields: [curriculumId], references: [id])

  progress StudentProgress[]
}

model Lesson {
  id           String       @id @default(cuid())
  therapistId  String
  studentId    String
  title        String
  date         DateTime
  startTime    String // "09:00"
  endTime      String // "10:00"
  note         String?
  isRecurring  Boolean      @default(false)
  recurringDay Int? // 0=Pazar, 1=Pazartesi ... 6=Cumartesi
  status       LessonStatus @default(PLANNED)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  therapist  Therapist         @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  student    Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exceptions LessonException[]

  @@index([therapistId])
  @@index([date])
}

model LessonException {
  id           String        @id @default(cuid())
  lessonId     String
  originalDate DateTime
  title        String?
  startTime    String?
  endTime      String?
  status       LessonStatus?
  note         String?

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([originalDate])
}

model StudentProgress {
  id        String   @id @default(cuid())
  status    String // "not_started" | "in_progress" | "completed"
  notes     String?
  updatedAt DateTime @updatedAt

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  goalId String
  goal   CurriculumGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  therapistId String
  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@unique([studentId, goalId])
  @@index([therapistId])
  @@index([status])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user Therapist @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Denetim kaydı — admin eylemleri ve hassas değişiklikler için değiştirilmez
// trail. Ödeme uyuşmazlıklarında ve regülasyon sorgularında kritik.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String? // null = sistem (webhook, scheduled job, vb.)
  action     String // "plan.update" | "credits.grant" | "user.suspend" | "role.change" | "subscription.create" | ...
  targetType String // "therapist" | "subscription" | "credit" | ...
  targetId   String
  diff       Json? // önceki → yeni değerler (opsiyonel, hassas alanlar hariç)
  ip         String?
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
  @@index([actorId])
  @@index([createdAt])
}

// Ödeme sağlayıcı webhook idempotency kaydı. Aynı externalId'li webhook
// tekrar gelirse cached durumu döneriz; iyzico gibi sağlayıcılar retry
// yaptığı için bu kritik.
model WebhookDelivery {
  id          String    @id @default(cuid())
  provider    String // "iyzico" | "stripe" | ...
  externalId  String // sağlayıcıdan gelen benzersiz olay kimliği
  status      String    @default("received") // "received" | "processed" | "failed"
  attempts    Int       @default(1)
  payload     Json
  error       String?   @db.Text
  receivedAt  DateTime  @default(now())
  processedAt DateTime?

  @@unique([provider, externalId])
  @@index([status])
  @@index([receivedAt])
}
