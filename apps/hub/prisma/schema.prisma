// LudenLab — MERKEZİ KİMLİK + BILLING ŞEMASI (hub / apex ludenlab.com)
//
// KONUM: Studio Supabase'inde `billing` ŞEMASI (HUB_DATABASE_URL ...?schema=billing).
//   Studio'nun `public` CANLI tabloları (Therapist/Plan/Subscription/...) DOKUNULMAZ.
//   DDL `prisma/sql/0001_init_billing.sql` ile (additive raw SQL, pg) uygulanır —
//   `prisma migrate`/`db push` YOK (canlı proje; bkz. ROADMAP Prisma drift notu).
//   Bu dosya `prisma generate` (client tipleri) içindir; SQL buna BİREBİR uyar.
//   (Runtime'da Atölye gibi adapter-pg + search_path=billing kullanılacak — Faz B.)
//
// İLKE: klinik/PII modül DB'lerinde İZOLE; buraya GİRMEZ. Entitlement semantiği
//   (kredi/limit/pdf) modülde map'lenir; merkez yalnız kim+modül+tier+durum+dönem tutar.

generator client {
  // Prisma 7 yeni generator: custom output + monorepo dostu (runtime'ı @prisma/client'tan
  // import eder, harici @prisma/client-runtime-utils require ETMEZ). atolye ile client
  // paylaşmaz → clobber yok. gitignore'lu.
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
  // Bağlantı URL'i prisma.config.ts'te (Prisma 7: schema'da `url` desteklenmez).
  // Runtime'da adapter-pg + search_path=billing (lib/db.ts).
}

enum BillingModule {
  STUDIO
  ATOLYE
  BRYTAKIP
}

/// İç normalize abonelik durumu. (Erişim kararı: resolveEntitlement.)
enum SubscriptionStatus {
  PENDING
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

/// Merkezi kimlik = SSO otoritesi. Modül hesapları (Studio.Therapist / Atolye.Account)
/// e-posta ile buna map'lenir (varsayım: 1 e-posta = 1 kişi).
model Account {
  id                String   @id @default(cuid())
  email             String   @unique
  name              String?
  passwordHash      String
  role              String   @default("user") // user | admin
  suspended         Boolean  @default(false)
  // Üyelik e-posta doğrulaması — gate: doğrulanmadan giriş yok (auth.ts). DDL: sql/0002_*.sql.
  emailVerified      Boolean   @default(false)
  emailVerifyToken   String?   @unique
  emailVerifyExpires DateTime?
  // KVKK rızası — kayıtta onay kutusu işaretlenince zaman damgası yazılır. DDL: sql/0005_*.sql.
  kvkkAcceptedAt     DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  subscriptions Subscription[]

  @@index([email])
}

/// Plan kataloğu (fiyat otoritesi). Modül × tier × interval.
model BillingPlan {
  id               String          @id @default(cuid())
  module           BillingModule
  code             String // tier: "PRO" | "ADVANCED" | "ENTERPRISE" (FREE planda abonelik yok)
  interval         BillingInterval
  name             String // "Atölye Pro Aylık"
  price            Decimal         @db.Decimal(10, 2) // TL major-unit
  active           Boolean         @default(true)
  createdAt        DateTime        @default(now())

  subscriptions Subscription[]

  @@unique([module, code, interval])
  @@index([module])
}

/// Bir hesabın BİR modüldeki aboneliği.
model Subscription {
  id                    String             @id @default(cuid())
  accountId             String
  module                BillingModule
  billingPlanId         String?
  pendingBillingPlanId  String? // zamanlanmış downgrade: yenileme cron'u gelecek dönemde uygular
  status                SubscriptionStatus @default(PENDING)
  // ── Paynkolay (nkolay VPOS) ──
  paynkolayClientRefCode String?           @unique // init'te üretilir; callback'i aboneliğe bağlar (idempotent)
  paynkolayCardToken     String? // csToken — saklı karttan yenileme (chargeStoredCard) için
  paynkolayCustomerKey   String? // csCustomerKey — token operasyonlarında zorunlu
  paynkolayRefCode       String? // son başarılı charge'ın Paynkolay REFERENCE_CODE'u (iptal/iade/iz)
  currentPeriodEnd      DateTime?
  cancelledAt           DateTime?
  lastSyncedPeriodEnd   DateTime? // callback↔webhook idempotency (mükerrer kredi/erişim yok)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  account     Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  billingPlan BillingPlan? @relation(fields: [billingPlanId], references: [id])

  @@index([accountId, module])
  @@index([module, status])
}

/// Tek apex webhook ucu için idempotency + iz. (Studio/Atölye WebhookDelivery deseni.)
model WebhookEvent {
  id          String         @id @default(cuid())
  provider    String         @default("paynkolay")
  eventType   String
  externalId  String         @unique // sağlayıcı olay kimliği → tekrarları engeller
  module      BillingModule? // route edilen modül (biliniyorsa)
  payload     Json
  status      String         @default("received") // received | processed | failed
  attempts    Int            @default(1)
  error       String?
  processedAt DateTime?
  createdAt   DateTime       @default(now())

  @@index([status])
  @@index([createdAt])
}

/// Paynkolay hosted-form ödeme niyeti. init'te oluşur (Subscription'a dokunmadan → mevcut
/// erişim korunur); callback CLIENT_REFERENCE_CODE ile eşleşir. PaymentList teyidinde
/// Subscription ACTIVE'e upsert edilir, intent CONSUMED'e geçer.
model PaymentIntent {
  id            String   @id @default(cuid())
  clientRefCode String   @unique
  accountId     String
  billingPlanId String
  status        String   @default("PENDING") // PENDING | CONSUMED
  createdAt     DateTime @default(now())

  @@index([accountId])
}
