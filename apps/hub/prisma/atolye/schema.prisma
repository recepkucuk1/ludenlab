// LudenLab Atölye — KLİNİK VERİ ŞEMASI (Faz 2 TASARIM TASLAĞI)
//
// ÖNEMLİ KURALLAR:
//  • Ayrı klinik DB (ATOLYE_DATABASE_URL); Studio/billing DB'sinden izole.
//  • RLS güvenlik-kritiktir (çocuk verisi). Şema/güvenlik değişiklikleri
//    VERSİYONLU migration ile uygulanır (prisma migrate). ASLA `db push` —
//    RLS/GRANT sessizce düşer (bkz. ROADMAP.md, Prisma drift notu).
//  • PII YOK: çocuğun gerçek adı yerine `code` (rumuz) tutulur.
//  • Faz 2'de bu yalnız TASARIM taslağıdır; Prisma client/bağlantı ve
//    BEP çıktılarının kalıcılığı sonraki artımda gelir. RLS: prisma/sql/rls.sql

generator client {
  provider = "prisma-client"
  output   = "../../src/generated/atolye"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

enum PlanType {
  FREE
  PRO
  ADVANCED
  ENTERPRISE
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

/// Merkezi kimlik (uzman/yönetici). Faz 6'da SSO ile ortak Account'a bağlanır;
/// şimdilik Atölye'nin yerel temsili — şema şekli ortak tutuluyor.
model Account {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         String   @default("practitioner") // practitioner | admin
  suspended    Boolean  @default(false) // askıya alınmış hesap → girişi engellenir
  planType     PlanType @default(FREE)
  credits      Int      @default(0) // kullanıcı kredi bakiyesi; araç üretimi düşer
  iyzicoCustomerRef String? // İyzico müşteri referans kodu

  // Profil — kullanıcının kendi düzenlediği hesap alanları (PII; AI'a gitmez).
  avatarUrl       String? @db.Text // küçük data-URL (≤300KB, kare 200px, jpeg)
  specialty       String[] @default([]) // uzmanlık alan(lar)ı; ilk eleman birincil
  institution     String? // çalışılan kurum / merkez
  phone           String?
  experienceYears String? // serbest aralık etiketi (ör. "3-5", "10+")
  certifications  String? @db.Text // lisans / sertifika notları
  preferences     Json? // varsayılan araç tercihleri (kademe, zorluk, toggle'lar)

  // Destek erişimi (KVKK rıza) — kullanıcı, ekibin hesabına geçici erişimine izin verir.
  supportAccessExpiresAt DateTime? // null veya geçmiş = izin yok
  supportAccessReason    String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cases         Case[]
  sessions      Session[]
  creditTxns    CreditTransaction[]
  subscriptions Subscription[]
}

/// Bir öğrenci kaydı (Öğrenci Bilgi Sistemi). `code` = Ad Soyad (kimlik); öğrenme
/// profiliyle birlikte AI araçlarına gider. İletişim (okul/veli) PII'dir; yalnız
/// uzmanın roster'ında görünür, AI'a gitmez (KVKK rıza + RLS hardening gerekir).
model Case {
  id      String @id @default(cuid())
  ownerId String
  code    String // Ad Soyad — öğrenci kimliği (AI'a gider)
  kademe  String

  // Öğrenme profili (araçlar otomatik doldurur; AI'a gider)
  yas          Int?
  taniProfili  String[] @default([])
  guclukDuzeyi String?
  gucluYonler  String?  @db.Text
  ilgiAlanlari String?
  // Çalışılan MEB hedef alanları — bölüm kodları (ör. "3.1", "5.2"); modül koddan türetilir.
  mebBolumler  String[] @default([])

  // İletişim PII — yalnız roster; AI'a gitmez
  okul         String?
  veliIletisim String? @db.Text
  notes        String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner     Account             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  documents GeneratedDocument[]
  sessions  Session[]

  @@index([ownerId])
}

/// AI ile üretilmiş TASLAK çıktı (BEP hedef / ilerleme raporu / aile özeti).
model GeneratedDocument {
  id        String   @id @default(cuid())
  caseId    String
  type      String // bep_hedef | ilerleme_raporu | aile_ozeti
  content   String   @db.Text
  model     String
  credits   Int      @default(0)
  // MEB hedef hizalaması (opsiyonel) — bu taslak hangi resmî hedef/davranışlar üzerinde çalışıldı.
  // `mebHedefKod` ör. "5.1.14" (modül.bölüm.hedef); modül/bölüm koddan türetilebilir.
  mebHedefKod        String?
  mebDavranisKodlari String[] @default([])
  createdAt DateTime @default(now())

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

/// Seans / randevu (takvim). PII içermez — vakaya (rumuz) bağlanır.
model Session {
  id           String   @id @default(cuid())
  ownerId      String
  caseId       String?
  title        String
  date         DateTime @db.Date
  startTime    String // "HH:MM"
  endTime      String
  note         String?  @db.Text
  status       String   @default("PLANNED") // PLANNED | COMPLETED | CANCELLED
  isRecurring  Boolean  @default(false)
  recurringDay Int? // 0=Pazartesi … 6=Pazar (tekrar eden seanslar)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner      Account            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  case       Case?              @relation(fields: [caseId], references: [id], onDelete: SetNull)
  exceptions SessionException[]

  @@index([ownerId])
  @@index([caseId])
}

/// Tekrar eden bir seansın TEK occurrence'ı için override/iptal ("bu seans").
/// status="CANCELLED" → o gün atlanır; diğer alanlar doluysa o günü override eder.
model SessionException {
  id           String   @id @default(cuid())
  sessionId    String
  originalDate DateTime @db.Date // override edilen occurrence günü
  title        String?
  startTime    String?
  endTime      String?
  status       String?
  note         String?  @db.Text

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, originalDate])
  @@index([sessionId])
}

/// Kredi defteri. EARN: plan/grant (+), SPEND: araç üretimi (−). Bakiye = Account.credits.
/// (iyzico/abonelik en sona; şimdilik FREE plan + grant + harcama.)
model CreditTransaction {
  id        String   @id @default(cuid())
  accountId String
  amount    Int // + kazanım / − harcama
  type      String // EARN | SPEND
  reason    String
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
}

/// AI üretim kullanım/maliyet kaydı (admin gözlem). FK yok (hesap silinse de iz kalır).
model ApiUsageLog {
  id              String   @id @default(cuid())
  accountId       String?
  model           String
  inputTokens     Int      @default(0)
  outputTokens    Int      @default(0)
  cacheReadTokens Int      @default(0)
  costUsd         Float    @default(0)
  credits         Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([accountId, createdAt])
}

/// Yönetsel işlem izi (rol değişimi, askıya alma, hesap silme…). actorId null = sistem.
/// FK YOK (hesap silinse de iz kalır); aktör adı görüntülerken manuel enrich edilir.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String? // işlemi yapan admin hesabı (null = sistem)
  action     String // "role.change" | "account.suspend" | "account.delete" …
  targetType String // "account" …
  targetId   String
  diff       Json? // {from,to} ya da işleme özel ayrıntı
  ip         String?
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
  @@index([createdAt])
}

model Plan {
  id           String   @id @default(cuid())
  type         PlanType @unique
  creditAmount Int // dönem başı yüklenen kredi
  monthlyPrice Int // kuruş cinsinden (37900 = 379 TL)
  yearlyPrice  Int // kuruş cinsinden
  // ── iyzico referans alanları ──
  iyzicoProductRef     String? // iyzico ürün referans kodu
  iyzicoMonthlyPlanRef String? // aylık planın iyzico referans kodu
  iyzicoYearlyPlanRef  String? // yıllık planın iyzico referans kodu
  createdAt    DateTime @default(now())

  subscriptions Subscription[]
}

model Subscription {
  id               String             @id @default(cuid())
  accountId        String
  planId           String
  status           SubscriptionStatus @default(PENDING)
  billingCycle     BillingCycle
  currentPeriodEnd DateTime
  // ── iyzico referans alanları ──
  iyzicoSubscriptionRef String?        @unique // iyzico subscription reference code
  iyzicoPricingPlanRef  String?                // seçilen iyzico plan referansı
  cancelledAt           DateTime?              // iptal tarihi
  lastCreditedPeriodEnd DateTime?              // bu dönem için kredi yüklendi mi (callback↔webhook idempotency)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  plan    Plan    @relation(fields: [planId], references: [id])

  @@index([accountId])
}

model WebhookDelivery {
  id          String    @id @default(cuid())
  provider    String // "iyzico" | "stripe" | ...
  externalId  String // sağlayıcıdan gelen benzersiz olay kimliği
  status      String    @default("received") // "received" | "processed" | "failed"
  attempts    Int       @default(1)
  payload     Json
  error       String?   @db.Text
  receivedAt  DateTime  @default(now())
  processedAt DateTime?

  @@unique([provider, externalId])
  @@index([status])
  @@index([receivedAt])
}
