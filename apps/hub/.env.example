# apps/hub — LudenLab apex: merkezi billing + kimlik (artık SUNUCU app).
# Gerçek .env COMMIT EDİLMEZ (.env gitignored).
#
# Merkezi DB = Studio Supabase'i, `billing` şeması (Studio `public` tabloları dokunulmaz).
HUB_DATABASE_URL=postgresql://USER:PASS@HOST:5432/postgres?sslmode=require&schema=billing

# iyzico — apex tek merchant. Önce SANDBOX; prod öncesi gerçek anahtar + base URL.
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_MERCHANT_ID=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# next-auth (Faz B) — cross-subdomain SSO
AUTH_SECRET=
# AUTH_URL=https://ludenlab.com
# COOKIE_DOMAIN=.ludenlab.com

# Apex base URL (iyzico callbackUrl + redirect)
NEXT_PUBLIC_APP_URL=https://ludenlab.com
