# apps/hub — LudenLab apex: merkezi billing + kimlik (artık SUNUCU app).
# Gerçek .env COMMIT EDİLMEZ (.env gitignored).
#
# Merkezi DB = Studio Supabase'i, `billing` şeması (Studio `public` tabloları dokunulmaz).
HUB_DATABASE_URL=postgresql://USER:PASS@HOST:5432/postgres?sslmode=require&schema=billing
# Studio domain DB = AYNI Supabase projesi (kgbhvruzoaqwwwkhzdex), public şema (Therapist/Card/GeneratedImage).
STUDIO_DATABASE_URL=postgresql://USER:PASS@HOST:5432/postgres?sslmode=require

# iyzico — apex tek merchant. Önce SANDBOX; prod öncesi gerçek anahtar + base URL.
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_MERCHANT_ID=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# next-auth (Faz B) — cross-subdomain SSO
AUTH_SECRET=
# AUTH_URL doğrulama e-postası linkinin tabanı — PROD'DA SET EDİLMELİ (yoksa link localhost'a düşer).
AUTH_URL=https://ludenlab.com
# COOKIE_DOMAIN=.ludenlab.com

# Apex base URL (iyzico callbackUrl + redirect)
NEXT_PUBLIC_APP_URL=https://ludenlab.com

# Üyelik e-posta doğrulaması — Hostinger SMTP (nodemailer). Hesaplar Hostinger'da açık.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465                              # 465 = SSL/TLS · 587 = STARTTLS
SMTP_USER=noreply@ludenlab.com            # tam e-posta (info@ da olabilir)
SMTP_PASS=                                 # mailbox şifresi
EMAIL_FROM=LudenLab <noreply@ludenlab.com>

# ── Görsel üretim (Faz 2+) ──
# Görsel sağlayıcısı: openai (varsayılan) | flux
IMAGE_PROVIDER=openai
OPENAI_API_KEY=
# FAL_KEY=                                 # IMAGE_PROVIDER=flux ise

# Supabase Storage (tool-images bucket = Studio projesi kgbhvruzoaqwwwkhzdex).
# SERVICE_ROLE_KEY GİZLİDİR — yalnız sunucu .env'inde, commit edilmez.
SUPABASE_URL=https://kgbhvruzoaqwwwkhzdex.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
TOOL_IMAGES_BUCKET=tool-images
