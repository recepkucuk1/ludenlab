// LudenLab Atölye — KLİNİK VERİ ŞEMASI (Faz 2 TASARIM TASLAĞI)
//
// ÖNEMLİ KURALLAR:
//  • Ayrı klinik DB (ATOLYE_DATABASE_URL); Studio/billing DB'sinden izole.
//  • RLS güvenlik-kritiktir (çocuk verisi). Şema/güvenlik değişiklikleri
//    VERSİYONLU migration ile uygulanır (prisma migrate). ASLA `db push` —
//    RLS/GRANT sessizce düşer (bkz. ROADMAP.md, Prisma drift notu).
//  • PII YOK: çocuğun gerçek adı yerine `code` (rumuz) tutulur.
//  • Faz 2'de bu yalnız TASARIM taslağıdır; Prisma client/bağlantı ve
//    BEP çıktılarının kalıcılığı sonraki artımda gelir. RLS: prisma/sql/rls.sql

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Merkezi kimlik (uzman/yönetici). Faz 6'da SSO ile ortak Account'a bağlanır;
/// şimdilik Atölye'nin yerel temsili — şema şekli ortak tutuluyor.
model Account {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         String   @default("practitioner") // practitioner | admin
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cases    Case[]
  sessions Session[]
}

/// Bir öğrenci kaydı (Öğrenci Bilgi Sistemi). `code` = Ad Soyad (kimlik); öğrenme
/// profiliyle birlikte AI araçlarına gider. İletişim (okul/veli) PII'dir; yalnız
/// uzmanın roster'ında görünür, AI'a gitmez (KVKK rıza + RLS hardening gerekir).
model Case {
  id      String @id @default(cuid())
  ownerId String
  code    String // Ad Soyad — öğrenci kimliği (AI'a gider)
  kademe  String

  // Öğrenme profili (araçlar otomatik doldurur; AI'a gider)
  yas          Int?
  taniProfili  String[] @default([])
  guclukDuzeyi String?
  gucluYonler  String?  @db.Text
  ilgiAlanlari String?

  // İletişim PII — yalnız roster; AI'a gitmez
  okul         String?
  veliIletisim String? @db.Text
  notes        String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner     Account             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  documents GeneratedDocument[]
  sessions  Session[]

  @@index([ownerId])
}

/// AI ile üretilmiş TASLAK çıktı (BEP hedef / ilerleme raporu / aile özeti).
model GeneratedDocument {
  id        String   @id @default(cuid())
  caseId    String
  type      String // bep_hedef | ilerleme_raporu | aile_ozeti
  content   String   @db.Text
  model     String
  credits   Int      @default(0)
  createdAt DateTime @default(now())

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

/// Seans / randevu (takvim). PII içermez — vakaya (rumuz) bağlanır.
model Session {
  id           String   @id @default(cuid())
  ownerId      String
  caseId       String?
  title        String
  date         DateTime @db.Date
  startTime    String // "HH:MM"
  endTime      String
  note         String?  @db.Text
  status       String   @default("PLANNED") // PLANNED | COMPLETED | CANCELLED
  isRecurring  Boolean  @default(false)
  recurringDay Int? // 0=Pazartesi … 6=Pazar (tekrar eden seanslar)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner Account @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  case  Case?   @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([caseId])
}
