# LudenLab Atölye — ortam değişkenleri
# Gerçek .env COMMIT EDİLMEZ.

# Claude (BEP & Rapor Asistanı) — zorunlu
ANTHROPIC_API_KEY=

# Klinik DB (ayrı, izole). Faz 2'de henüz wired değil (tasarım taslağı).
