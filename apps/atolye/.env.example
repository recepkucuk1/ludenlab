# LudenLab Atölye — ortam değişkenleri
# Gerçek .env COMMIT EDİLMEZ.

# Claude (BEP & Seans araçları) — zorunlu
ANTHROPIC_API_KEY=

# Klinik DB (ayrı, izole). BYPASSRLS yetkisi OLMAYAN bir uygulama rolü kullanın.
ATOLYE_DATABASE_URL=postgresql://USER:PASS@HOST:5432/atolye

# next-auth (v5) — zorunlu. Üret: openssl rand -base64 32
AUTH_SECRET=
# Prod'da uygulama kökü (örn. https://atolye.ludenlab.com); local'de gerekmez
# AUTH_URL=

# hCaptcha (opsiyonel — secret tanımlıysa kayıt formunda doğrulama enforce edilir)
# HCAPTCHA_SECRET=
# NEXT_PUBLIC_HCAPTCHA_SITEKEY=

# Uygulama URL'i (prod: https://atolye.ludenlab.com)
NEXT_PUBLIC_APP_URL=http://localhost:3002
