# LudenLab Atölye — ortam değişkenleri
# Gerçek .env COMMIT EDİLMEZ.

# Claude (BEP & Seans araçları) — zorunlu
ANTHROPIC_API_KEY=

# Klinik DB (ayrı, izole). BYPASSRLS yetkisi OLMAYAN bir uygulama rolü kullanın.
ATOLYE_DATABASE_URL=postgresql://USER:PASS@HOST:5432/atolye

# next-auth (v5) — zorunlu. Üret: openssl rand -base64 32
AUTH_SECRET=
# Prod'da uygulama kökü (örn. https://atolye.ludenlab.com); local'de gerekmez
# AUTH_URL=

# hCaptcha (opsiyonel — secret tanımlıysa kayıt formunda doğrulama enforce edilir)
# HCAPTCHA_SECRET=
# NEXT_PUBLIC_HCAPTCHA_SITEKEY=

# Uygulama URL'i (prod: https://atolye.ludenlab.com). iyzico callback bunu kullanır.
NEXT_PUBLIC_APP_URL=http://localhost:3002

# ── iyzico abonelik ödemesi ──────────────────────────────────────────────────
# Sandbox: https://sandbox-api.iyzipay.com · Prod: https://api.iyzipay.com
# Anahtarlar iyzico panelinden. Merchant hesabı studio/brytakip ile paylaşımlı.
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_MERCHANT_ID=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Webhook çok-kiracılı router: bu DB'de olmayan abonelikler brytakip'e iletilir.
# BRYTAKIP_WEBHOOK_URL=https://brytakip.com/api/webhooks/iyzico

# Abonelik iptal temizliği (günlük cron) için paylaşılan sır.
# Üret: openssl rand -base64 32
CRON_SECRET=
