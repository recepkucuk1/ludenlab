# Hostinger'da pnpm 11 (corepack ile) çalışıyor; bu repo packageManager=pnpm@9.15.4'e
# pinli. Corepack altındaki pnpm sürüm değiştiremediği için "Failed to install
# dependencies" veriyordu. Strict kontrolü kapatıyoruz → her pnpm sürümü mevcut
# lockfile ile kurulum yapabilir (pnpm 9 lockfile'ı pnpm 11 tarafından okunabilir).
# Yerel/CI 9.15.4 kullanmaya devam eder; bu yalnız sürüm-eşleşme zorlamasını gevşetir.
package-manager-strict=false
